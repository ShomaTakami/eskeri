{
  "expo": {
    "name": "エスケリ",
    "slug": "eskeri",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/eskeri-icon/app-icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#f8f9fb",
    "splash": {
      "image": "./assets/eskeri-icon/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f9fb"
    },
    "androidNavigationBar": {
      "backgroundColor": "#f8f9fb",
      "barStyle": "dark-content"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/eskeri-icon/app-icon.png",
        "backgroundColor": "#f8f9fb"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.shomatakami.eskeri"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/eskeri-icon/app-icon.png",
          "color": "#111827"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ddc9a632-be97-4460-b839-b275f6634374"
      }
    }
  }
}
